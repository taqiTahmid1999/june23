<html>
  <head>
    <title>{{ shop.name }}</title>
    {{ content_for_header }}
    {{ 'counter.js' | asset_url | script_tag }}
    <script src="{{ 'main.js' | asset_url }}" type="module" defer></script>
  </head>
  <body>
    {{ content_for_layout }}
    <h1 x-data="{message: 'Hello World, Dude!'}" x-text="message"></h1>
    <div x-data="{ count : 0}">
      <button @click="count++">Increament</button>
      <p x-text="count"></p>
    </div>
    <div x-data="{open: false}">
      <p x-show="open" @click.outside="open= false">
        Lorem ipsum dolor sit amet consectetur adipisicing elit. Libero saepe quo sapiente tenetur? Facere eligendi ad
        magnam non rerum sit?
      </p>
      <button @click="open = ! open">Toggle</button>
    </div>
  </body>
</html>
