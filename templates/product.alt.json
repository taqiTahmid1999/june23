{
  // LAYOUT (optional) — which layout file wraps this template
  // omit = layout/theme.liquid (default) | "full-width" = layout/full-width.liquid | false = bare page, no layout, NOT customizable in theme editor
  "layout": "different",
  // WRAPPER (optional) — wraps ALL sections in ONE HTML element
  // syntax: tag#id.class[attr=value] — tag must be div, main, or section ONLY (no other tags allowed)
  // renders as: <tag id="id" class="class" attr="value"> ...all sections... </tag>

  // SECTIONS (required) — defines every section on the page
  "sections": {
    // section ID: your internal label, alphanumeric only, unique within this template
    "main": {
      // type: REQUIRED, must match a .liquid filename in /sections (no extension)
      // missing file = error. App sections are the only exception to this rule
      "type": "counter"
      // disabled: optional bool, default false — true = hidden on storefront but still editable in theme editor
      // settings: optional — keys MUST match setting IDs defined in this section's schema
    }
  },

  // ORDER (required) — array of section IDs, top-to-bottom render order
  // IDs must EXACTLY match keys in "sections" above, no duplicates allowed
  // this is the array merchants rearrange in the theme editor
  "order": ["main"]
}
